# ===== CSQAQ API =====
# 在 CSQAQ 官网：登录 -> 点击头像 -> 查看 ApiToken -> 复制后粘贴到等号后面。
# 请先在 CSQAQ 官网完成“自动获取”或“手动绑定白名单 IP”。
CSQAQ_API_TOKEN=你的api key
CSQAQ_API_BASE_URL=https://api.csqaq.com/api/v1

# ===== 套利计算规则（已按当前确认的第一版需求填写） =====
# 85 折：Steam 标价 0.60 元，实际现金成本为 0.60 * 0.85 = 0.51 元。
STEAM_WALLET_DISCOUNT=0.615
# Steam 最高求购价固定加 0.10 元后，再乘 Steam 钱包折扣率。
STEAM_BID_INCREMENT_CNY=0.10
# BUFF 手续费率：1.5%
BUFF_FEE_RATE=0.015
# 只展示严格大于 10% 的机会。
MIN_NET_PROFIT_RATE=0.10

# ===== 第一版扫描节奏 =====
# 初始自动从 CSQAQ 默认目录顺序中，筛选出前 50 件非特殊款式饰品。
INITIAL_SAMPLE_SIZE=200
# CSQAQ 公共 API 单 IP 最多 1 次/秒；这里故意设为 1.05 秒留余量。
REQUEST_INTERVAL_SECONDS=1.05
# 15 分钟 = 900 秒。
SCAN_INTERVAL_SECONDS=900
# 本地网页自动刷新秒数。
DASHBOARD_REFRESH_SECONDS=30

# ===== 本地网页 =====
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
DASHBOARD_OPEN_BROWSER=true

# ===== 链接模板 =====
# 程序会自动把 Steam 英文 market_hash_name 做 URL 编码后填入 {market_hash_name}。
STEAM_LISTING_URL_TEMPLATE=https://steamcommunity.com/market/listings/730/{market_hash_name}
# 程序会把 API 返回的 buff_id 填入 {buff_id}。
BUFF_GOODS_URL_TEMPLATE=https://buff.163.com/goods/{buff_id}?from=market

# ===== 明确过滤：不计算、不展示 =====
# 关键词命中中文名或 Steam 英文名后，会直接跳过。
EXCLUDED_KEYWORDS_CN=多普勒,伽马多普勒,淬火,表面淬火,渐变,黑珍珠,红宝石,蓝宝石,翡翠
EXCLUDED_KEYWORDS_EN=Doppler,Case Hardened,Fade,Black Pearl,Ruby,Sapphire,Emerald
